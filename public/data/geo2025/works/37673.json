40585%2C130.960614"},{"id":"d4w21un80","geo":[30.540863,130.960514],"priority":5,"name":"中央種子島高校：駐輪場","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","image":"/images/points/37673/d4w21un80_1695200987454.jpg","ep":1,"s":"","mark":"カイたちがバイクを停める場所。","density":33,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.540863%2C130.960514"},{"id":"d4w21unb8","geo":[30.540971,130.961781],"priority":8,"name":"中央種子島高校：昇降口","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"中には入れないのでゲームCGの通りの絵は撮れません。","density":53,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.540971%2C130.961781"},{"id":"d4w21umsg","geo":[30.541438,130.96187],"priority":5,"name":"中央種子島高校：渡り廊下","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"ジュンちゃんが漏らしそうになった場所。","density":53,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.541438%2C130.96187"},{"id":"d4w21un77","geo":[30.541482,130.961086],"priority":40,"name":"中央種子島高校：中庭（ロボ部部室前）","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","image":"/images/user/0/bangumi/37673/points/d4w21un77-1779878872012.jpg","ep":"1","s":"3:48","mark":"よくカイが木陰でキルバラをしている場所。","density":87,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.541482%2C130.961086"},{"id":"d4w21unbh","geo":[30.539784,130.96007],"priority":125,"name":"伊禮商店（アイSHOP永井店）","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","uid":1081,"image":"/images/user/1081/bangumi/37673/points/d4w21unbh-1729757080753.jpg","s":115,"mark":"「伊禮商店」の元ネタのコンビニ。「フルーツサワーメロン」は売っていないらしい。島内でもあまり売っていないとか。","density":16,"origin":"@passion","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.539784%2C130.96007"},{"id":"d4w21umu1","geo":[30.537733,130.958988],"priority":110,"name":"B-COOP(Ａコープ中種子店)","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"アキちゃんがよく名前を出していたスーパー。CGでは登場しない。チェーン店なので南の方にもある。","density":257,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.537733%2C130.958988"},{"id":"d4w21unab","geo":[30.528655,130.969304],"priority":71,"name":"中種子町陸上競技場","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"君島レポートのフラグ立てで、カイが自転車でトラックを回った公園。使用されている時は入れないらしいので、未使用の時を狙いましょう。","density":1525,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.528655%2C130.969304"},{"id":"d4w21umvg","geo":[30.731645,130.989893],"priority":4,"name":"西之表港","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"「あねもね号」の元になった「プリンセスわかさ」が停泊する港。ストリートビューでも「プリンセスわかさ」がちょっと見えます。近くに「火縄銃の会」というのがあり、年に数回、火縄銃を撃てるイベントがあるそうです。君島レポートのフラグ立てを体験したい場合は日取りを確認しましょう。","density":5924,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.731645%2C130.989893"},{"id":"d4w21unb1","geo":[30.761727,131.033981],"priority":5392,"name":"あっぽ～らんど","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"色が変わったという湖のある場所。","density":5924,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.761727%2C131.033981"},{"id":"d4w21un3w","geo":[30.610986,130.950149],"priority":3673,"name":"雄龍・雌龍の岩","cn":"雄龍・雌龍の岩","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","uid":1007,"image":"/images/user/1007/bangumi/37673/points/d4w21un3w-1695524797193.jpg","ep":15,"s":"","mark":"「君島レポートNO.6」のあった場所。ARアノテーションの位置は鳥居。少し南の辺りに昴の自宅がある（という設定）。","density":7442,"origin":"@Narcissu","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.610986%2C130.950149"},{"id":"d4w21umvh","geo":[30.545945,130.931324],"priority":2476,"name":"長浜海岸","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"フラグ立てでサーフィンした場所。めちゃくちゃ長い海岸なので、モデルになった場所の正確な位置は不明。","density":2475,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.545945%2C130.931324"},{"id":"d4w21umnp","geo":[30.447457,130.970051],"priority":190,"name":"浜田海水浴場","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"「君島レポートNo.3」があった場所。ARアノテーションの位置は千座の岩屋の真上。フラグ立てで小石を乗せた鳥居は、2012年8月現在、破損のため撤去されてしまったそうです。","density":189,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.447457%2C130.970051"},{"id":"d4w21umsi","geo":[30.447129,130.971724],"priority":1425,"name":"千座の岩屋","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"「君島レポートNo.3」のフラグ立てで、ARアノテーションを3日連続3時間映し続けた場所。大潮の時でもないと3時間も潮が引いていないらしい。潮が引いていないと岩屋内には入れない（にくい）ため、巡礼時は干潮時間を考えて来ましょう。","density":189,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.447129%2C130.971724"},{"id":"d4w21umt3","geo":[30.451088,130.95952],"priority":3784,"name":"メヒルギの花","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"「君島レポートNo.3」のフラグ、「メヒルギの花を撮影して居ル夫。にアップロードする」のメヒルギがあります。干潟に見えるマングローブの一部がメヒルギです。7、8月頃白い花を咲かせます。「マングローブ」は植物名じゃないよ。","density":1236,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.451088%2C130.95952"},{"id":"d4w21umqh","geo":[30.438365,130.927901],"priority":1273,"name":"長谷展望公園","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"「君島レポートNo.4」があった場所。ARアノテーションの位置は休憩所のテーブルの足。","density":1273,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.438365%2C130.927901"},{"id":"d4w21un3t","geo":[30.398234,130.902989],"priority":2195,"name":"宇宙ヶ丘公園（展望台）","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","uid":1007,"image":"/images/user/1007/bangumi/37673/points/d4w21un3t-1695524842230.jpg","ep":5,"s":"","mark":"「君島レポートNo.2」があった場所。ARアノテーションはロケット型のモニュメントの天辺。カイがよくキルバラをやりにくる公園の展望台。","density":84,"origin":"@Narcissu","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.398234%2C130.902989"},{"id":"d4w21un3r","geo":[30.398961,130.903214],"priority":85,"name":"南種子町郷土館（旧中種子町郷土館）","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"「君島レポートNo.1」のあった場所。ARアノテーションは建物内、天井の蛍光灯付近。道路側からでも見える、カイが登ったアンテナが目印。アンテナの元に行く裏手には草がボウボウで、マムシが出るかもしれないので注意。2012年8月現在、取り壊し予定もあるそうなので巡礼する場合は急いだほうがいいかも。","density":84,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.398961%2C130.903214"},{"id":"d4w21umxw","geo":[30.444139,130.917994],"priority":761,"name":"ロボクリニック？","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"地図上ではこの辺り。ストリートビューからでは確認不可。","density":760,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.444139%2C130.917994"},{"id":"d4w21un4y","geo":[30.438513,130.914088],"priority":13,"name":"通学路(国道58号線)","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"カイとアキちゃんが通学に使う道路。ゲーム中では左右反転されている。ガンつく1を移動する際もここを通る。","density":12,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.438513%2C130.914088"},{"id":"d4w21ump2","geo":[30.438427,130.914021],"priority":2660,"name":"公立種子島病院","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","uid":1007,"image":"/images/user/1007/bangumi/37673/points/d4w21ump2-1695524898398.jpg","ep":12,"s":"","mark":"某イベントなどでお世話になる場所。","density":12,"origin":"@Narcissu","originURL":"https://www.google.com/maps/d/viewer?mid=1tiOp1zfOAc3gI-YbLWnIKlVCw_I&ll=30.438427%2C130.914021"},{"id":"d4w21ummz","geo":[30.403648,130.902389],"priority":448,"name":"海翔・あき穂自宅？","isFolder":false,"mid":"1tiOp1zfOAc3gI-YbLWnIKlVCw_I","s":"","mark":"地図上ではこの辺りの民家がモデルと思われる。それらしい建物があるかはストリートビューからでは確認不可。","density":447,"origin":"Googl