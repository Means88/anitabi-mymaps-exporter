3KOnW2VEC7v&ll=35.735539%2C139.713381"},{"id":"fdd55b71","geo":[35.735642,139.711995],"priority":91,"isFolder":false,"folder":"第5話のエージェントがホテルでマッピングした場所(適当)","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","density":154,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=35.735642%2C139.711995"}],"tags":[],"priority":999,"icon":"/images/icon/312979_nmyup9yxm.jpg","modified":1724828644833,"pointsLength":43,"imagesLength":0},"points":[{"id":"e709e87f","geo":[35.679727,139.712517],"priority":100,"name":"東京体育館(第1話・第3話・第5話)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"2002年の全日本体操競技選手権大会会場(※)で、城太郎は鉄棒で失敗し天草コーチから引退宣告させられるきっかけとなった(第1話) 鉄男との非公開の勝負に際して、城太郎と天草コーチがビデオで鉄男の演技を研究した際の大会会場もここである(第3話) 2003年5月30日(金)・31日(土)に行われ城太郎や鉄男たちが出場した第43回 NHK杯 体操の会場としても登場(第5話)1954年に東京都体育館として開館し、1964年の東京オリンピックでは体操競技とプールの会場となる。1990年に全面改築し、このとき東京体育館に名称変更。延期が決定した2020年の東京オリンピック・パラリンピックの卓球会場として改修工事が行われる。※実際の2002年大会は静岡で行われた。","density":99,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=35.679727%2C139.712517"},{"id":"aa39670d","geo":[35.730191,139.708905],"priority":9,"name":"池袋西口公園(第1話〜第3話)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"城太郎が天草コーチから引退宣告され夜に帰宅前に思案したり(第1話)、例の引退会見後クビ宣告されて昼間ベンチで腰かけたり、ブリトニー発案の太極拳を行った公園。昼間ベンチで腰かけていた姿は週刊星雲のカメラマンに撮影されていて記事に使用された(第3話)。のちにドラマ化・アニメ化する石田衣良の小説「池袋ウエストゲートパーク」のタイトル元でも有名。","density":18,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=35.730191%2C139.708905"},{"id":"f225ba59","geo":[36.7908,139.69746],"priority":615,"name":"日光江戸村(第1話)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"城太郎・玲父子が遊びに行き、エージェントに終われる忍者(レオナルド)と初対面した江戸時代の文化や生活が集大成したテーマパーク(第1話)(ちなみに、あまり大きな声では言えないが、ニャンまげのデザイン原案者と東京オリンピックエンブレム騒動の人は同じ人物。)","density":117134,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=36.7908%2C139.69746"},{"id":"f5300d4b","geo":[35.682095,139.589929],"priority":499,"name":"四つ葉スポーツクラブ体育館内(塚原体操センター(朝日生命体操クラブ)) (第1話-)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"城太郎の所属する四つ葉スポーツクラブの体育館内部のモデル。また、エンディングの協力クレジットにも「塚原体操センター 事務局」名義で掲載されている。","density":6298,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=35.682095%2C139.589929"},{"id":"7af2071d","geo":[35.733799,139.7148],"priority":91,"name":"スナックマリー(第2話-)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"城太郎の母・マリが経営し、レオやあゆが働くスナック。※初登場の時点で高架道路のスロープ部脇にあることは認識していたものの場所を特定できず。第6話で両隣がコインパーキングと薬局と判明、玲が佇んでいたパークブリッジを探したついでに池袋大橋から伸びるスロープ部沿いをストリートビューで確認したところ判明。","density":90,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=35.733799%2C139.7148"},{"id":"046dd845","geo":[35.730099,139.709601],"priority":9,"name":"整骨院 川本が入居する池袋のビル(第2話)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"スナックマリーの常連・ブリトニーが勤める整骨院が入居するビルのモデル(3階以上の作りはアニメオリジナルか)","density":8,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=35.730099%2C139.709601"},{"id":"5e0afc8c","geo":[35.73005,139.709659],"priority":14,"name":"整骨院 川本の外観ショット(第2話)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"スナックマリーの常連・ブリトニーがレオナルドに渡した名刺に記載の住所で検索すると実在することを確認。隣接ビルもアニメで表現されている。","density":8,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v&ll=35.73005%2C139.709659"},{"id":"d3c8c103","geo":[35.717636,139.71389],"priority":5,"name":"のぞき坂(第3話・第5話)","isFolder":false,"folder":"舞台マップ","mid":"1XnOga-5R8kxTPnbJUIE3v3KOnW2VEC7v","s":"","mark":"城太郎