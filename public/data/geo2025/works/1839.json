_1740589811455.jpg","ep":4,"s":843,"density":2,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1Oi-jP742uH2EhRzrdhIcvw14r7Y&ll=34.487594%2C136.694797"},{"id":"kpx6oj6yf","geo":[34.48759,136.694818],"priority":1261,"name":"宇治山田高等学校前","isFolder":false,"mid":"1Oi-jP742uH2EhRzrdhIcvw14r7Y","image":"/images/points/1839/kpx6oj6yf_1740589821639.jpg","ep":4,"s":854,"density":2,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1Oi-jP742uH2EhRzrdhIcvw14r7Y&ll=34.48759%2C136.694818"},{"id":"t83mhsgiy","geo":[34.483386,136.716343],"priority":604,"name":"虎尾山","isFolder":false,"uid":2150,"image":"/images/points/1839/t83mhsgiy_1740590242948.jpg","ep":6,"s":228,"density":16,"origin":"@concert","originURL":""},{"id":"6gmmcml","geo":[34.483929,136.715682],"priority":75,"name":"伊勢岡本ヒルズ公園(虎尾山入口)","isFolder":false,"uid":2183,"s":"","mark":"虎尾山入口就在这里，虎尾山是半月最重要的剧情发生地，也是粉丝最大的交流场所，山上的箱子内留存着大量的交流笔记，登山请务必小心，虽然虎尾山的攀登难度很低，但因为道路年久失修，仍然存在一些危险。","density":74,"origin":"@澄蔦","originURL":""},{"id":"kpx6oj57r","geo":[34.487528,136.714033],"priority":189,"name":"まんぷく食堂","isFolder":false,"mid":"1Oi-jP742uH2EhRzrdhIcvw14r7Y","s":"","mark":"虽然在动画中没有出现，但在小说中登场了。\n半月粉丝交流场所，有非常多的留言本，和老板沟通也会热情回复。","density":190,"origin":"Google My Maps","originURL":"https://www.google.com/maps/d/viewer?mid=1Oi-jP742uH2EhRzrdhIcvw14r7Y&ll=34.487528%2C136.714033"},{"id":"6gkwoem","geo":[34.493153,136.698203],"priority":344,"name":"伊勢慶友病院遗","isFolder":false,"uid":2183,"s":"","mark":"作品医院原型之一，原作医院设定地点。目前伊勢慶友病院已拆除，更名成伊勢ひかり病院并移动新的地址重建。原址则是新开了一家叫ぎゅーとら的超市。","density":344,"origin":"@澄蔦","originURL":""},{"id":"6glgsz2","geo":[34.459522,136.723248],"priority":23,"name":"赤福 内宮前支店","isFolder":false,"uid":2183,"s":"","mark":"番外篇one day里香和裕一吃的赤福，也是唯一有沿街长凳的赤福。裕一吃了赤福氷，小说中同时也提到了赤福ぜんざい，但两者无法一次性凑齐，赤福ぜんざい是冬季限定，赤福氷是夏季限定。","density":1197,"origin":"@澄蔦","originURL":""},{"id":"6glwnxo","geo":[34.469323,136.718749],"priority":913,"name":"古市参宮街道","isFolder":false,"uid":2183,"s":"","mark":"裕一骑自行车载着里香前往内宫的道路，从动画的小田桥，经过炮台山，最后从猿田彦神社旁边小路驶出，也正如小说提到的那样有一段陡峭的上坡。","density":1197,"origin":"@澄蔦","originURL":""},{"id":"6gm6e9x","geo":[34.492623,136.705651],"priority":202,"name":"月夜見宮","isFolder":false,"uid":2183,"s":"","mark":"小说中美雪和山西约定见面，为里香和裕一拿取结婚申请书的地点。","density":201,"origin":"@澄蔦","originURL":""}]}