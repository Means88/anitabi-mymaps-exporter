{
  "manifest_version": 3,
  "name": "Anitabi My Maps Exporter",
  "description": "Export Anitabi pilgrimage points to CSV or KML for Google My Maps.",
  "version": "0.1.1",
  "icons": {
    "16": "dist/icons/icon-16.png",
    "32": "dist/icons/icon-32.png",
    "48": "dist/icons/icon-48.png",
    "128": "dist/icons/icon-128.png"
  },
  "action": {
    "default_title": "Anitabi Exporter",
    "default_popup": "dist/src/popup.html",
    "default_icon": {
      "16": "dist/icons/icon-16.png",
      "32": "dist/icons/icon-32.png",
      "48": "dist/icons/icon-48.png",
      "128": "dist/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "dist/extension/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.anitabi.cn/map*",
        "https://anitabi.cn/map*"
      ],
      "js": [
        "dist/extension/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/index.html",
        "dist/src/popup.html",
        "dist/favicon.ico",
        "dist/favicon.svg",
        "dist/apple-touch-icon.png",
        "dist/icons/*",
        "dist/assets/*",
        "dist/fonts/*",
        "dist/extension/*"
      ],
      "matches": [
        "https://www.anitabi.cn/*",
        "https://anitabi.cn/*"
      ]
    }
  ],
  "permissions": [
    "activeTab",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://api.anitabi.cn/*",
    "https://www.anitabi.cn/d/g.json"
  ]
}
